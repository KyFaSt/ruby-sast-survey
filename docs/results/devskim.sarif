ub.com/presidentbeef/brakeman/blob/main/lib/brakeman/checks/check_model_attr_accessible.rb\"],\"category\":\"security\",\"technology\":[\"ruby\"],\"owasp\":[\"A08:2021 - Software and Data Integrity Failures\"],\"subcategory\":[\"audit\"],\"likelihood\":\"LOW\",\"impact\":\"MEDIUM\",\"confidence\":\"LOW\",\"license\":\"Semgrep Rules License v1.0. For more details, visit semgrep.dev/legal/rules-license\",\"vulnerability_class\":[\"Mass Assignment\"],\"source\":\"https://semgrep.dev/r/ruby.lang.security.model-attr-accessible.model-attr-accessible\",\"shortlink\":\"https://sg.run/jNrZ\",\"semgrep.dev\":{\"rule\":{\"origin\":\"community\",\"r_id\":9721,\"rule_id\":\"bwUOAG\",\"rv_id\":946487,\"url\":\"https://semgrep.dev/playground/r/pZTNOK6/ruby.lang.security.model-attr-accessible.model-attr-accessible\",\"version_id\":\"pZTNOK6\"}}},\"severity\":\"ERROR\",\"fingerprint\":\"287b77b644483d172e754d6045185e89258bc4ceb59f92850a5fd2a573626deaa1581dfcdceb1713abad91a9582eb76bd6b6d60c14004076e0687d5151d4c477","markdown":"`license\":\"Semgrep Rules License v1.0. For more details, visit semgrep.dev/legal/rules-license\",\"vulnerability_class\":[\"Code Injection\"],\"source\":\"https://semgrep.dev/r/ruby.lang.security.dangerous-subshell.dangerous-subshell\",\"shortlink\":\"https://sg.run/NrxL\",\"semgrep.dev\":{\"rule\":{\"origin\":\"community\",\"r_id\":9827,\"rule_id\":\"OrUGn8\",\"rv_id\":946474,\"url\":\"https://semgrep.dev/playground/r/RGTAgzG/ruby.lang.security.dangerous-subshell.dangerous-subshell\",\"version_id\":\"RGTAgzG\"}}},\"severity\":\"WARNING\",\"fingerprint\":\"9b98efa259881cb63ef7a117e9cfc4f4b62b6394ad067cccd4ba0bbf680476e3e97bcf5e32ef2c308054ce764907ce6737811118e970647ea2e9f72834ecc7d9_0\",\"lines\":\"    `ping -c 1 #{host}`\",\"is_ignored\":false,\"validation_state\":\"NO_VALIDATOR\",\"engine_kind\":\"OSS\"}},{\"check_id\":\"ruby.lang.security.dangerous-subshell.dangerous-subshell\",\"path\":\"app.rb\",\"start\":{\"line\":15,\"col\":5,\"offset\":301},\"end\":{\